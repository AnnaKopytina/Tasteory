erDiagram
    Categories ||--o{ Categories : "родительская"
    Categories ||--o{ Items : "группирует"
    Brands ||--o{ Items : "бренд"
    Prices ||--o{ Items : "цена"
    Users ||--o{ Carts : "владеет"
    Carts ||--o{ ItemsToCarts : "содержит"
    Items ||--o{ ItemsToCarts : "добавлен"
    Users ||--o{ Orders : "создает"
    Carts ||--o| Orders : "оформлена как"
    PaymentStatus ||--o{ Orders : "статус"
    Orders ||--o{ OrdersToItems : "включает"
    Items ||--o{ OrdersToItems : "в позиции"
    DeliveryStatus ||--o{ OrdersToItems : "статус товара"

    Items {
        serial id PK
        int category_id FK
        string title
        text description
        int brand_id FK
        int price_id FK
        int code "Уникальный артикул"
        int weight "в граммах"
        int available_count
    }

    Categories {
        serial id PK
        int parent_id FK "Self-reference"
        string title
    }

    Brands {
        serial id PK
        string title
    }

    Prices {
        serial id PK
        int price "Копейки/рубли"
    }

    Users {
        serial id PK
        string name
    }

    Carts {
        serial id PK
        int user_id FK
        int count "Кол-во товаров"
    }

    ItemsToCarts {
        serial id PK
        int cart_id FK
        int item_id FK
    }

    Orders {
        serial id PK
        string delivery_address
        int user_id FK
        int cart_id FK
        int payment_status_id FK
    }

    PaymentStatus {
        serial id PK
        string title "Оплачен/Ожидает"
    }

    OrdersToItems {
        serial id PK
        int order_id FK
        int item_id FK
        int delivery_status_id FK
    }

    DeliveryStatus {
        serial id PK
        string title "В пути/Доставлен"
    }